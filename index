'home'), goMod = this.go('modules'), goOverview = this.go('overview'), goLesson = this.go('lesson'), goEd = this.startEdfinity, goSyl = this.go('syllabus'), goAnn = this.go('announcements'), goStart = this.go('start');\n\n    const navDefs = [\n      ['home', 'Home'], ['syllabus', 'Syllabus'], ['announcements', 'Announcements'], ['modules', 'Modules']\n    ];\n    const activeKey = page === 'home' ? 'home' : page === 'syllabus' ? 'syllabus' : page === 'announcements' ? 'announcements' : 'modules';\n    const courseNav = navDefs.map(([k, label]) => {\n      const active = k === activeKey;\n      const handler = k === 'home' ? goHome : k === 'modules' ? goMod : k === 'syllabus' ? goSyl : k === 'announcements' ? goAnn : undefined;\n      return {\n        label, onClick: handler, onKey: this.keyActivate(handler),\n        role: handler ? 'button' : null, tabIndex: handler ? 0 : null, ariaCurrent: active ? 'page' : null,\n        style: 'padding:7px 14px;font-size:14px;cursor:' + (handler ? 'pointer' : 'default') + ';border-left:4px solid ' +\n          (active ? maroon : 'transparent') + ';color:' + (active ? '#2d3b45' : maroon) +\n          ';font-weight:' + (active ? '700' : '400')\n      };\n    });\n\n    const crumbDefs = page === 'home'\n      ? [['Brief Calculus', true]]\n      : page === 'modules' ? [['Brief Calculus', false], ['Modules', true]]\n      : page === 'overview' ? [['Brief Calculus', false], ['Modules', false], ['Module 1 Overview', true]]\n      : page === 'lesson' ? [['Brief Calculus', false], ['Modules', false], ['1.1 Rates of Change', true]]\n      : page === 'syllabus' ? [['Brief Calculus', false], ['Syllabus', true]]\n      : page === 'announcements' ? [['Brief Calculus', false], ['Announcements', true]]\n      : [['Brief Calculus', false], ['Modules', false], ['Edfinity 1.1: Rates of Change', true]];\n    const crumbs = crumbDefs.map(([label, cur], i) => ({\n      label, lead: i === 0 ? '' : '/',\n      style: 'font-size:13.5px;' + (cur ? 'co