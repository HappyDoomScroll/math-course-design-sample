ize:16px;font-weight:700;color:#1f2933\">Average rate of change =<\u002Flabel>\n                <input id=\"ed-answer\" type=\"text\" value=\"{{ edAnswer }}\" oninput=\"{{ onEdInput }}\" placeholder=\"?\" aria-label=\"Average rate of change answer\" style=\"width:92px;padding:9px 12px;font-size:16px;font-family:inherit;text-align:center;border:1.5px solid #b7c0c4;border-radius:6px;outline:none\" style-focus=\"border-color:#8c1d40;box-shadow:0 0 0 3px rgba(140,29,64,.28)\">\n                <span style=\"font-size:15px;color:#46505a\">{{ edProb.unit }}<\u002Fspan>\n              <\u002Fdiv>\n\n              <div style=\"display:flex;gap:10px;margin-top:20px\">\n                <button onclick=\"{{ edSubmit }}\" style=\"background:#16a394;color:#fff;border:none;border-radius:6px;padding:11px 24px;font-size:15px;font-weight:700;cursor:pointer;font-family:inherit\" style-hover=\"background:#118475\">Submit Answer<\u002Fbutton>\n                <button onclick=\"{{ edReset }}\" style=\"background:#fff;color:#46505a;border:1px solid #c7cdd1;border-radius:6px;padding:11px 20px;font-size:15px;font-weight:700;cursor:pointer;font-family:inherit\" style-hover=\"background:#f2f4f5\">Clear<\u002Fbutton>\n              <\u002Fdiv>\n\n              <sc-if value=\"{{ isCorrect }}\" hint-placeholder-val=\"{{ false }}\">\n                <div style=\"margin-top:20px;background:#e7f6ee;border:1px solid #a8dcc0;border-radius:8px;padding:16px 18px;color:#15623b;font-size:15px;line-height:1.6\"><strong>Correct! <\u002Fstrong><span style=\"color:#3a6b52\">{{ edProb.explain }}<\u002Fspan>\n                  <div style=\"margin-top:13px\"><button onclick=\"{{ edNext }}\" style=\"background:#16a394;color:#fff;border:none;border-radius:6px;padding:10px 22px;font-size:14.5px;font-weight:700;cursor:pointer;font-family:inherit\" style-hover=\"background:#118475\">{{ edNextLabel }} ›<\u002Fbutton><\u002Fdiv>\n                <\u002Fdiv>\n              <\u002Fsc-if>\n\n              <sc-if value=\"{{ isWrong }}\" hint-placeholder-val=\"{{ false }}\">\n                <div style=\"margin-top:20px;background:#fdeced;border:1px solid #f1b4ba;border-radius:8px;padding:15px 17px;color:#8a1c2a;font-size:15px;line-height:1.6\"><strong>Not quite. <\u002Fstrong>Use the difference quotient over the given interval, then try again.\n                  <div style=\"margin-top:9px\"><a onclick=\"{{ openHint }}\" style=\"color:#8c1d40;font-weight:700;cursor:pointer;text-decoration:underline\">▶ Replay the support video<\u002Fa><\u002Fdiv>\n                <\u002Fdiv>\n              <\u002Fsc-if>\n              <\u002Fsc-if>\n\n              <sc-if value=\"{{ edCompleted }}\" hint-placeholder-val=\"{{ false }}\">\n              <div style=\"text-align:center;padding:14px 10px 6px\">\n                <div style=\"width:64px;height:64px;border-radius:50%;background:#e7f6ee;border:2px solid #16a394;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:30px;color:#16a394;font-weight:900\">✓<\u002Fdiv>\n                <div style=\"font-size:22px;font-weight:900;color:#1f2933;margin-bottom:8px\">All problems complete<\u002Fdiv>\n                <p style=\"margin:0 auto 22px;max-width:440px;font-size:15.5px;line-height:1.6;color:#5b6770\">Nice work — you worked through all {{ edTotal }} problems in this set. Mark the activity as complete to record it in your Modules progress.<\u002Fp>\n\n                <sc-if value=\"{{ edMarkedDone }}\" hint-placeholder-val=\"{{ false }}\">\n                  <div style=\"display:inline-flex;align-items:center;gap:9px;background:#e7f6ee;border:1px solid #a8dcc0;border-radius:8px;padding:12px 22px;color:#15623b;font-weight:700;font-size:15px\"><span style=\"width:20px;height:20px;border-radius:50%;background:#16a394;color:#fff;display:inline-flex;align-items:center;justify-content:center;font-size:12px\">✓<\u002Fspan>Marked as complete<\u002Fdiv>\n                <\u002Fsc-if>\n                <sc-if value=\"{{ edMarkedNotYet }}\" hint-placeholder-val=\"{{ true }}\">\n                  <div style=\"display:flex;gap:10px;justify-content:center;flex-wrap:wrap\">\n                    <button onclick=\"{{ edMarkDone }}\" style=\"background:#8c1d40;color:#fff;border:none;border-radius:6px;padding:12px 26px;font-size:15px;font-weight:700;cursor:pointer;font-family:inherit\" style-hover=\"background:#76152f\">Mark as complete<\u002Fbutton>\n                    <button onclick=\"{{ edRestart }}\" style=\"background:#fff;color:#46505a;border:1px solid #c7cdd1;border-radius:6px;padding:12px 22px;font-size:15px;font-weight:700;cursor:pointer;font-family:inherit\" style-hover=\"background:#f2f4f5\">Try a new set<\u002Fbutton>\n                  <\u002Fdiv>\n                <\u002Fsc-if>\n              <\u002Fdiv>\n              <\u002Fsc-if>\n\n            <\u002Fdiv>\n          <\u002Fdiv>\n\n          <div style=\"display:flex;justify-content:space-between;gap:16px;border-top:1px solid #e8eaec;margin-top:26px;padding-top:18px\">\n            <button onclick=\"{{ goLesson }}\" style=\"display:flex;align-items:center;gap:9px;background:#fff;border:1px solid #c7cdd1;border-radius:4px;padding:10px 16px;cursor:pointer;font-family:inherit;text-align:left\" style-hover=\"background:#f5f6f7\">\n              <span style=\"font-size:18px;color:#5c6670\">‹<\u002Fspan>\n              <span><span style=\"display:block;font-size:11px;color:#5c6670;font-weight:700\">BACK TO<\u002Fspan><span style=\"font-size:14px;font-weight:700;color:#8c1d40\">1.1 Rates of Change<\u002Fspan><\u002Fspan>\n            <\u002Fbutton>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <\u002Fsc-if>\n\n        <!-- ============ START HERE ============ -->\n        <sc-if value=\"{{ isStart }}\" hint-placeholder-val=\"{{ true }}\">\n        <div style=\"max-width:1060px;margin:0 auto;padding:26px 30px 50px\">\n          <div style=\"display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:18px\">\n            <h1 style=\"margin:0;font-size:27px;font-weight:700;line-height:1.2\">Start Here<\u002Fh1>\n            \n          <\u002Fdiv>\n\n          <div style=\"background:#f5f5f7;border:1px solid #e6e6e6;border-radius:12px;padding:30px\">\n\n            <!-- WELCOME -->\n            <div style=\"background:#fff;border-radius:10px;padding:26px;margin-bottom:26px\">\n              <h2 style=\"display:flex;align-items:center;margin:0 0 16px;font-size:22px;font-weight:700;color:#222;border-bottom:1px solid #e1e1e1;padding-bottom:13px\">{{ icTopics }}Welcome &amp; How This Course Works<\u002Fh2>\n              <p style=\"margin:0 0 12px;font-size:16px;line-height:1.7\">Welcome to <strong>MAT210: Brief Calculus<\u002Fstrong> — this page is your home base. The course runs on a simple weekly loop: read the guided notes, watch the lecture, practice in Edfinity, then connect with your classmates and instructor. Everything you need each week lives inside that week's module.<\u002Fp>\n              <p style=\"margin:0;font-size:16px;line-height:1.7\">When you're ready, head into <strong>Module 1<\u002Fstrong> and follow the four steps below each week. Consistency beats cramming in this course — a steady rhythm is the best predictor of success.<\u002Fp>\n            <\u002Fdiv>\n\n            <!-- WEEKLY ROUTINE -->\n            <div style=\"background:#fff;border-radius:10px;padding:26px;margin-bottom:26px\">\n              <h2 style=\"display:flex;align-items:center;margin:0 0 16px;font-size:22px;font-weight:700;color:#222;border-bottom:1px solid #e1e1e1;padding-bottom:13px\">{{ icBulb }}Your Weekly Routine<\u002Fh2>\n              <sc-for list=\"{{ routine }}\" as=\"s\" hint-placeholder-count=\"4\">\n                <div style=\"{{ s.rowStyle }}\">\n                  <div style=\"width:46px;height:46px;flex:none;border-radius:9px;background:#fbf2f5;color:#8c1d40;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:15px\">{{ s.num }}<\u002Fdiv>\n                  <div style=\"flex:1;min-width:0\">\n                    <div style=\"font-weight:700;font-size:16.5px;color:#1f2933\">{{ s.title }}<\u002Fdiv>\n                    <div style=\"font-size:14.5px;color:#5b6770;line-height:1.55;margin-top:3px\">{{ s.text }}<\u002Fdiv>\n                  <\u002Fdiv>\n                <\u002Fdiv>\n              <\u002Fsc-for>\n            <\u002Fdiv>\n\n            <!-- GET HELP -->\n            <div style=\"background:#fff;border-radius:10px;padding:26px\">\n              <h2 style=\"display:flex;align-items:center;margin:0 0 16px;font-size:22px;font-weight:700;color:#222;border-bottom:1px solid #e1e1e1;padding-bottom:13px\">{{ icPolicy }}How to Get Help<\u002Fh2>\n              <ul style=\"margin:0;padding-left:20px;font-size:15.5px;line-height:1.9\">\n                <li><strong>Office hours:<\u002Fstrong> Tuesdays &amp; Thursdays, 1–3pm on Zoom — drop in anytime.<\u002Fli>\n                <li><strong>Weekly live session:<\u002Fstrong> Thursdays at 6pm for worked examples and Q&amp;A (recorded).<\u002Fli>\n                <li><strong>Discussions:<\u002Fstrong> Post a question anytime — your instructor and classmates reply.<\u002Fli>\n                <li><strong>Tutoring:<\u002Fstrong> Free drop-in math tutoring through the Student Support Hub.<\u002Fli>\n                <li><strong>Tech support:<\u002Fstrong> 24/7 help for Canvas and Edfinity via the Help menu.<\u002Fli>\n              <\u002Ful>\n            <\u002Fdiv>\n\n          <\u002Fdiv>\n\n          <div style=\"display:flex;justify-content:flex-end;gap:16px;border-top:1px solid #e8eaec;margin-top:26px;padding-top:18px\">\n            <button onclick=\"{{ goOverview }}\" style=\"display:flex;align-items:center;gap:9px;background:#fff;border:1px solid #c7cdd1;border-radius:4px;padding:10px 16px;cursor:pointer;font-family:inherit;text-align:right\" style-hover=\"background:#f5f6f7\">\n              <span><span style=\"display:block;font-size:11px;color:#5c6670;font-weight:700\">NEXT<\u002Fspan><span style=\"font-size:14px;font-weight:700;color:#8c1d40\">Module 1: Foundations &amp; Rates of Change<\u002Fspan><\u002Fspan>\n              <span style=\"font-size:18px;color:#5c6670\">›<\u002Fspan>\n            <\u002Fbutton>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <\u002Fsc-if>\n\n        <!-- ============ SYLLABUS ============ -->\n        <sc-if value=\"{{ isSyllabus }}\" hint-placeholder-val=\"{{ true }}\">\n        <div style=\"max-width:1060px;margin:0 auto;padding:26px 30px 50px\">\n          <div style=\"display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:18px\">\n            <h1 style=\"margin:0;font-size:27px;font-weight:700;line-height:1.2\">Course Syllabus<\u002Fh1>\n            \n          <\u002Fdiv>\n\n          <div style=\"background:#f5f5f7;border:1px solid #e6e6e6;border-radius:12px;padding:30px\">\n\n            <div style=\"width:100%;height:180px;border-radius:10px;background:repeating-linear-gradient(45deg,#e8e3e6,#e8e3e6 11px,#ddd6da 11px,#ddd6da 22px);display:flex;align-items:center;justify-content:center;color:#8c6675;font-family:'SFMono-Regular',Menlo,monospace;font-size:13px;margin-bottom:26px\">syllabus banner image — 1020×180<\u002Fdiv>\n\n            <div style=\"background:#fff;border-radius:10px;padding:22px 24px;margin-bottom:26px\">\n              <h2 style=\"margin:0 0 8px;font-size:20px;font-weight:700;color:#222\">Welcome to MAT210<\u002Fh2>\n              <p style=\"margin:0 0 16px;font-size:15.5px;line-height:1.65;color:#46505a\">This syllabus is your reference for everything in Brief Calculus — how the course runs, what's graded, and where to get help. Skim it now and come back anytime. Use the quick links below to jump to any section.<\u002Fp>\n              <a href=\"#\" download=\"\" style=\"display:inline-flex;align-items:center;gap:8px;background:#8c1d40;color:#fff;text-decoration:none;border-radius:6px;padding:11px 18px;font-size:14px;font-weight:700\" style-hover=\"background:#76152f\" style-focus=\"outline:2px solid #8c1d40;outline-offset:2px\">⬇ Download syllabus (PDF)<\u002Fa>\n            <\u002Fdiv>\n\n            <div id=\"syl-menu\" style=\"background:#fff;border-radius:10px;padding:18px 20px;margin-bottom:26px\">\n              <div style=\"font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:.5px;color:#646d75;margin-bottom:12px\">Jump to a section<\u002Fdiv>\n              <div style=\"display:flex;flex-wrap:wrap;gap:10px\">\n                <sc-for list=\"{{ sylSections }}\" as=\"s\" hint-placeholder-count=\"6\">\n                  <button onclick=\"{{ s.onClick }}\" style=\"background:#fbf2f5;color:#8c1d40;border:1px solid #ecd6de;border-radius:20px;padding:8px 16px;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit\" style-hover=\"background:#f4e2e8\">{{ s.label }}<\u002Fbutton>\n                <\u002Fsc-for>\n              <\u002Fdiv>\n            <\u002Fdiv>\n\n            <!-- COURSE INFO -->\n            <div id=\"syl-info\" style=\"background:#fff;border-radius:10px;padding:26px;margin-bottom:26px\">\n              <h2 style=\"display:flex;align-items:center;margin:0 0 18px;font-size:22px;font-weight:700;color:#222;border-bottom:1px solid #e1e1e1;padding-bottom:13px\">{{ icTopics }}Course Information<\u002Fh2>\n              <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:14px 28px\">\n                <div style=\"font-size:15px\"><span style=\"color:#646d75;font-weight:700\">Instructor<\u002Fspan><br>Dr. Rosa Medina<\u002Fdiv>\n                <div style=\"font-size:15px\"><span style=\"color:#646d75;font-weight:700\">Email<\u002Fspan><br>r.medina@example.edu<\u002Fdiv>\n                <div style=\"font-size:15px\"><span style=\"color:#646d75;font-weight:700\">Office Hours<\u002Fspan><br>Tue &amp; Thu, 1–3pm (Zoom)<\u002Fdiv>\n                <div style=\"font-size:15px\"><span style=\"color:#646d75;font-weight:700\">Credit Hours<\u002Fspan><br>3<\u002Fdiv>\n                <div style=\"font-size:15px\"><span style=\"color:#646d75;font-weight:700\">Modality<\u002Fspan><br>Online · weekly live session Thu 6pm<\u002Fdiv>\n                <div style=\"font-size:15px\"><span style=\"color:#646d75;font-weight:700\">Prerequisites<\u002Fspan><br>MAT117 (College Algebra) or placement<\u002Fdiv>\n              <\u002Fdiv>\n              <div style=\"margin-top:16px;padding-top:12px;border-top:1px solid #f2f3f4;display:flex;justify-content:flex-end\"><button onclick=\"{{ backToMenu }}\" style=\"background:#fbf2f5;color:#8c1d40;border:1px solid #ecd6de;border-radius:20px;padding:7px 16px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;display:inline-flex;align-items:center;gap:5px\" style-hover=\"background:#f4e2e8\">↑ Back to menu<\u002Fbutton><\u002Fdiv>\n            <\u002Fdiv>\n\n            <!-- DESCRIPTION + OUTCOMES -->\n            <div id=\"syl-desc\" style=\"background:#fff;border-radius:10px;padding:26px;margin-bottom:26px\">\n              <h2 style=\"display:flex;align-items:center;margin:0 0 16px;font-size:22px;font-weight:700;color:#222;border-bottom:1px solid #e1e1e1;padding-bottom:13px\">{{ icNotes }}Course Description<\u002Fh2>\n              <p style=\"margin:0 0 14px;font-size:15.5px;line-height:1.7\">Brief Calculus develops the tools of differential and integral calculus with an emphasis on applications in business, economics, and the social sciences. Topics include rates of change, limits and continuity, derivatives and their rules, optimization and marginal analysis, and an introduction to integration.<\u002Fp>\n              <p style=\"margin:0 0 8px;font-size:15.5px;font-weight:700\">By the end of this course you will be able to:<\u002Fp>\n              <ul style=\"margin:0;padding-left:20px;font-size:15.5px;line-height:1.8\">\n                <li>Compute and interpret average and instantaneous rates of change.<\u002Fli>\n                <li>Differentiate algebraic, exponential, and logarithmic functions.<\u002Fli>\n                <li>Apply derivatives to optimization and marginal analysis in business settings.<\u002Fli>\n                <li>Use integration to measure accumulated change.<\u002Fli>\n              <\u002Ful>\n              <div style=\"margin-top:16px;padding-top:12px;border-top:1px solid #f2f3f4;display:flex;justify-content:flex-end\"><button onclick=\"{{ backToMenu }}\" style=\"background:#fbf2f5;color:#8c1d40;border:1px solid #ecd6de;border-radius:20px;padding:7px 16px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;display:inline-flex;align-items:center;gap:5px\" style-hover=\"background:#f4e2e8\">↑ Back to menu<\u002Fbutton><\u002Fdiv>\n            <\u002Fdiv>\n\n            <!-- MATERIALS -->\n            <div id=\"syl-materials\" style=\"background:#fff;border-radius:10px;padding:26px;margin-bottom:26px\">\n              <h2 style=\"display:flex;align-items:center;margin:0 0 16px;font-size:22px;font-weight:700;color:#222;border-bottom:1px solid #e1e1e1;padding-bottom:13px\">{{ icBook }}Required Materials<\u002Fh2>\n              <ul style=\"margin:0;padding-left:20px;font-size:15.5px;line-height:1.9\">\n                <li><strong>Course text<\u002Fstrong> — <em>Applied Calculus<\u002Fem>, provided free inside Canvas.<\u002Fli>\n                <li><strong>Edfinity<\u002Fstrong> online homework access (purchased once through Canvas).<\u002Fli>\n                <li><strong>Graphing tool<\u002Fstrong> — a graphing calculator or a free Desmos account.<\u002Fli>\n              <\u002Ful>\n              <div style=\"margin-top:16px;padding-top:12px;border-top:1px solid #f2f3f4;display:flex;justify-content:flex-end\"><button onclick=\"{{ backToMenu }}\" style=\"background:#fbf2f5;color:#8c1d40;border:1px solid #ecd6de;border-radius:20px;padding:7px 16px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;display:inline-flex;align-items:center;gap:5px\" style-hover=\"background:#f4e2e8\">↑ Back to menu<\u002Fbutton><\u002Fdiv>\n            <\u002Fdiv>\n\n            <!-- GRADING -->\n            <div id=\"syl-grading\" style=\"background:#fff;border-radius:10px;padding:26px;margin-bottom:26px\">\n              <h2 style=\"display:flex;align-items:center;margin:0 0 18px;font-size:22px;font-weight:700;color:#222;border-bottom:1px solid #e1e1e1;padding-bottom:13px\">{{ icGrade }}Grading<\u002Fh2>\n              <sc-for list=\"{{ grading }}\" as=\"g\" hint-placeholder-count=\"5\">\n                <div style=\"display:flex;justify-content:space-between;align-items:center;padding:11px 0;border-bottom:1px solid #eef0f1;font-size:15.5px\">\n                  <span>{{ g.label }}<\u002Fspan><span style=\"font-weight:700;color:#8c1d40\">{{ g.weight }}<\u002Fspan>\n                <\u002Fdiv>\n              <\u002Fsc-for>\n              <div style=\"margin-top:14px;font-size:13.5px;color:#5c6670\">Grade scale: A 90–100 · B 80–89 · C 70–79 · D 60–69 · E below 60.<\u002Fdiv>\n              <div style=\"margin-top:16px;padding-top:12px;border-top:1px solid #f2f3f4;display:flex;justify-content:flex-end\"><button onclick=\"{{ backToMenu }}\" style=\"background:#fbf2f5;color:#8c1d40;border:1px solid #ecd6de;border-radius:20px;padding:7px 16px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;display:inline-flex;align-items:center;gap:5px\" style-hover=\"background:#f4e2e8\">↑ Back to menu<\u002Fbutton><\u002Fdiv>\n            <\u002Fdiv>\n\n            <!-- POLICIES -->\n            <div id=\"syl-policies\" style=\"background:#fff;border-radius:10px;padding:26px;margin-bottom:26px\">\n              <h2 style=\"display:flex;align-items:center;margin:0 0 16px;font-size:22px;font-weight:700;color:#222;border-bottom:1px solid #e1e1e1;padding-bottom:13px\">{{ icPolicy }}Course Policies<\u002Fh2>\n              <ul style=\"margin:0;padding-left:20px;font-size:15.5px;line-height:1.8\">\n                <li><strong>Late work:<\u002Fstrong> Edfinity allows a 48-hour grace window at reduced credit. Reach out early if life happens.<\u002Fli>\n                <li><strong>Academic integrity:<\u002Fstrong> Your work must be your own — always show your steps.<\u002Fli>\n                <li><strong>Accessibility:<\u002Fstrong> Accommodations are arranged through Student Accessibility; let me know early so we can plan.<\u002Fli>\n                <li><strong>Communication:<\u002Fstrong> I reply to messages within 24 hours on weekdays.<\u002Fli>\n              <\u002Ful>\n              <div style=\"margin-top:16px;padding-top:12px;border-top:1px solid #f2f3f4;display:flex;justify-content:flex-end\"><button onclick=\"{{ backToMenu }}\" style=\"background:#fbf2f5;color:#8c1d40;border:1px solid #ecd6de;border-radius:20px;padding:7px 16px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;display:inline-flex;align-items:center;gap:5px\" style-hover=\"background:#f4e2e8\">↑ Back to menu<\u002Fbutton><\u002Fdiv>\n            <\u002Fdiv>\n\n            <!-- COURSE SUMMARY -->\n            <div id=\"syl-summary\" style=\"background:#fff;border-radius:10px;padding:26px\">\n              <h2 style=\"display:flex;align-items:center;margin:0 0 8px;font-size:22px;font-weight:700;color:#222;border-bottom:1px solid #e1e1e1;padding-bottom:13px\">{{ icNotes }}Course Summary<\u002Fh2>\n              <sc-for list=\"{{ summary }}\" as=\"s\" hint-placeholder-count=\"3\">\n                <div style=\"display:flex;justify-content:space-between;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid #eef0f1;font-size:15px\">\n                  <span style=\"color:#8c1d40;font-weight:700\">{{ s.item }}<\u002Fspan><span style=\"color:#5c6670;flex:none\">{{ s.due }}<\u002Fspan>\n                <\u002Fdiv>\n              <\u002Fsc-for>\n              <div style=\"margin-top:16px;padding-top:12px;border-top:1px solid #f2f3f4;display:flex;justify-content:flex-end\"><button onclick=\"{{ backToMenu }}\"