gn-items:center;justify-content:center;background:repeating-linear-gradient(45deg,#1c1c1c,#1c1c1c 12px,#242424 12px,#242424 24px)\">\n            <div style=\"width:64px;height:64px;border-radius:50%;background:rgba(255,255,255,.95);display:flex;align-items:center;justify-content:center\"><div style=\"width:0;height:0;border-left:19px solid #8c1d40;border-top:12px solid transparent;border-bottom:12px solid transparent;margin-left:5px\"><\u002Fdiv><\u002Fdiv>\n          <\u002Fdiv>\n          <div style=\"position:absolute;left:14px;bottom:11px;color:#b9b9b9;font-family:'SFMono-Regular',Menlo,monospace;font-size:12px\">support video — 3:12<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"display:flex;justify-content:flex-end;gap:10px;padding:0 22px 22px\">\n        <button onclick=\"{{ closeHint }}\" style=\"background:#8c1d40;color:#fff;border:none;border-radius:6px;padding:11px 22px;font-weight:700;font-size:14px;cursor:pointer;font-family:inherit\" style-hover=\"background:#76152f\">Got it — try again<\u002Fbutton>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n  <\u002Fsc-if>\n\n<\u002Fdiv>\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\">\nclass Component extends DCLogic {\n  state = { page: 'home', welcomeDismissed: false, showHintModal: false, hintSeenThisProblem: false,\n    edProblems: this.buildEdProblems(), edIndex: 0, edAnswer: '', edStatus: null, edCompleted: false, edMarkedDone: false };\n\n  edProblemPool() {\n    return [\n      { lead: \"A startup's revenue R (in thousands of dollars) after t months is modeled by\", eq: 'R(t) = t\\u00B2', question: 'Find the average rate of change of revenue from t = 1 to t = 3 months.', answer: 4, unit: 'thousand $ / month', explain: '(R(3) \\u2212 R(1)) / (3 \\u2212 1) = (9 \\u2212 1)/2 = 4.' },\n      { lead: \"A delivery route's distance D (in miles) after t hours is given by\", eq: 'D(t) = 3t + 2', question: 'Find the average rate of change of distance from t = 0 to t = 4 hours.', answer: 3, unit: 'miles / hour', explain: '(D(4) \\u2212 D(0)) / (4 \\u2212 0) = (14 \\u2212 2)/4 = 3. The function is linear, so the rate is constant.' },\n      { lead: \"A product's profit P (in thousands of dollars) at output level x is\", eq: 'P(x) = x\\u00B2 + 1', question: 'Find the average rate of change of profit from x = 1 to x = 4 units.', answer: 5, unit: 'thousand $ / unit', explain: '(P(4) \\u2212 P(1)) / (4 \\u2212 1) = (17 \\u2212 2)/3 = 5.' },\n      { lead: 'A tank holds V (in liters) of water after t minutes, where', eq: 'V(t) = 2t\\u00B2', question: 'Find the average rate of change of volume from t = 0 to t = 3 minutes.', answer: 6, unit: 'liters / minute', explain: '(V(3) \\u2212 V(0)) / (3 \\u2212 0) = (18 \\u2212 0)/3 = 6.' }\n    ];\n  }\n  shuffle(a) { for (let i = a.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); const t = a[i]; a[i] = a[j]; a[j] = t; } return a; }\n  buildEdProblems() { return this.shuffle(this.edProblemPool()); }\n\n  go(p) { return () => this.setState({ page: p }); }\n  startEdfinity = () => this.setState({ page: 'edfinity', edProblems: this.buildEdProblems(), edIndex: 0, edAnswer: '', edStatus: null, edCompleted: false, edMarkedDone: false, hintSeenThisProblem: false, showHintModal: false });\n  onEdInput = (e) => this.setState({ edAnswer: e.target.value });\n  edSubmit = () => {\n    const p = this.state.edProblems[this.state.edIndex];\n    const v = parseFloat(this.state.edAnswer);\n    const correct = !isNaN(v) && Math.abs(v - p.answer) < 1e-9;\n    if (correct) { this.setState({ edStatus: 'correct', showHintModal: false }); }\n    else {\n      const first = !this.state.hintSeenThisProblem;\n      this.setState({ edStatus: 'wrong', showHintModal: first, hintSeenThisProblem: true });\n    }\n  };\n  edNext = () => {\n    const ni = this.state.edIndex + 1;\n    if (ni >= this.state.edProblems.length) this.setState({ edCompleted: true });\n    else this.setState({ edIndex: ni, edAnswer: '', edStatus: null, hintSeenThisProblem: false });\n  };\n  edReset = () => this.setState({ edAnswer: '', edStatus: null });\n  edMarkDone = () => this.setState({ edMarkedDone: true });\n  openHint = () => this.setState({ showHintModal: true });\n  closeHint = () => this.setState({ showHintModal: false });\n  dismissWelcome = () => this.setState({ welcomeDismissed: true });\n  keyActivate = (fn) => (ev) => { if (fn && (ev.key === 'Enter' || ev.key === ' ')) { ev.preventDefault(); fn(); } };\n  escClose = (ev) => { if (ev.key === 'Escape') this.closeHint(); };\n  sylScroll(id) { return () => { const c = document.getElementById('contentScroll'); const el = document.getElementById(id); if (c && el) { const top = el.getBoundingClientRect().top - c.getBoundingClientRect().top + c.scrollTop - 14; c.scrollTop = Math.max(0, top); } }; }\n\n  railIcon(type) {\n    const e = React.createElement;\n    const w = (kids) => e('svg', { width: 26, height: 26, viewBox: '0 0 24 24', fill: 'none', stroke: '#fff', strokeWidth: 1.5, strokeLinecap: 'round', strokeLinejoin: 'round', 'aria-hidden': 'true', focusable: 'false', style: { display: 'block' } }, kids);\n    if (type === 'account') return w([e('circle', { key: 1, cx: 12, cy: 8, r: 3.4 }), e('path', { key: 2, d: 'M5.5 19c.7-3.2 3.3-5 6.5-5s5.8 1.8 6.5 5' })]);\n    if (type === 'dashboard') return w([e('rect', { key: 1, x: 4, y: 4, width: 6.5, height: 6.5, rx: 1 }), e('rect', { key: 2, x: 13.5, y: 4, width: 6.5, height: 6.5, rx: 1 }), e('rect', { key: 3, x: 4, y: 13.5, width: 6.5, height: 6.5, rx: 1 }), e('rect', { key: 4, x: 13.5, y: 13.5, width: 6.5, height: 6.5, rx: 1 })]);\n    if (type === 'courses') return w([e('path', { key: 1, d: 'M12 5 3 9l9 4 9-4-9-4z' }), e('path', { key: 2, d: 'M6 11v4.5c0 1 2.7 2.5 6 2.5s6-1.5 6-2.5V11' })]);\n    if (type === 'calendar') return w([e('rect', { key: 1, x: 4, y: 5, width: 16, height: 15, rx: 1.5 }), e('path', { key: 2, d: 'M4 9h16M8 3v4M16 3v4' })]);\n    if (type === 'inbox') return 